generator client {
  provider = "prisma-client"
  output = "./generated"
}

datasource db {
  provider = "postgresql"
  //urlは書かない
}
model Station {
  id           Int      @id
  name         String
  layout       String
  main         String
  railnumber   Json
  outerterminal Json

  @@map("stations")//テーブル名の定義
}
model TrainType {
  id        String   @id @default(uuid())
  code      Int      @unique // oud2ファイル内での種別インデックス (0, 1, 2...)
  name      String   // 種別名 (例: 新快速)
  shortName String   // 略称 (例: 新快)
  color     String?  // 文字色・ダイヤ線色（必要に応じて）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // リレーション: 1つの種別に複数の列車が紐づく、Trainをまだ作っていない段階
  //trains    Train[]
}
model RailNumber {
  id         Int     @id @default(autoincrement())
  station_id Int
  rail_id    Int     // JSON内のid
  name       String
  ryakushou  String
}

model OuterTerminal {
  id         Int     @id @default(autoincrement())
  station_id Int
  terminal_id Int    // JSON内のid
  name       String
  jikoku     String
  diaryaku   String
}